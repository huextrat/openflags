{
  "name": "openflags",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "changeset": "bunx changeset",
    "compile": "bunx turbo run build",
    "dev": "bunx turbo run dev --parallel",
    "dev:dashboard": "bun run --cwd apps/dashboard dev",
    "dev:server": "bun run --cwd apps/server dev",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "install:clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules examples/*/node_modules && bun install",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "release": "bun run compile && bunx changeset publish",
    "test": "bunx turbo run test",
    "version": "bunx changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.0.0"
}
