{
  "name": "openflags",
  "private": true,
  "workspaces": ["apps/*", "packages/*", "examples/*"],
  "packageManager": "bun@1.0.0",
  "scripts": {
    "build": "bunx turbo run build",
    "dev": "bunx turbo run dev --parallel",
    "dev:server": "bun run --cwd apps/server dev",
    "dev:dashboard": "bun run --cwd apps/dashboard dev",
    "changeset": "bunx changeset",
    "version": "bunx changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
