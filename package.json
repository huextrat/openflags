{
  "name": "openflags",
  "private": true,
  "description": "Open source, self-hosted feature flags for modern JavaScript applications.",
  "homepage": "https://github.com/huextrat/openflags#readme",
  "bugs": {
    "url": "https://github.com/huextrat/openflags/issues"
  },
  "license": "MIT",
  "author": "Hugo Extrat <extrat.h@gmail.com> (https://github.com/huextrat)",
  "repository": {
    "type": "git",
    "url": "https://github.com/huextrat/openflags.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bunx turbo run build",
    "changeset": "bunx changeset",
    "dev": "bunx turbo run dev --filter=@openflagsdev/dashboard --filter=@openflagsdev/server --parallel",
    "dev:all": "bunx turbo run dev --parallel",
    "dev:dashboard": "bun run --cwd apps/dashboard dev",
    "dev:docs": "bun run --cwd apps/docs dev",
    "dev:server": "bun run --cwd apps/server dev",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "install:clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules examples/*/node_modules && bun install",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "release": "bun run build && bunx changeset publish",
    "test": "bunx turbo run test",
    "version": "bunx changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "turbo": "^2.8.15",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.0.0"
}
